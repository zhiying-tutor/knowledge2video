# ============================================================================
# Code2Video 环境变量配置
# 
# 使用方法：复制此文件为 .env，然后修改对应的值
#   cp .env.example .env
# ============================================================================

# --------------------------------------------------------------------------
# API 认证密钥（前端调用时需要在请求头中携带）
# 多个密钥用逗号分隔
# --------------------------------------------------------------------------
API_KEYS=dev-api-key-12345

# --------------------------------------------------------------------------
# 默认 LLM API（可选值: claude, gpt4o, gpt-41, gpt5, gemini）
# --------------------------------------------------------------------------
DEFAULT_API=claude

# --------------------------------------------------------------------------
# 端口配置
# --------------------------------------------------------------------------
API_PORT=8080
REDIS_PORT=6379

# --------------------------------------------------------------------------
# 并发配置（留空表示自动检测）
# --------------------------------------------------------------------------
MAX_WORKERS=

# --------------------------------------------------------------------------
# 调试模式（生产环境设为 false）
# --------------------------------------------------------------------------
DEBUG=false
